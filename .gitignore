# 敏感信息（永远不要提交）
.github_token
.feishu_webhook
.env
.env.local
.env.*.local
*.key
*.pem
*.crt
*.p12
*secret*
*password*

# 嵌套 git 仓库（防止历史问题 #2）
**/.git/
!.git/

# 临时文件
*.tmp
*.log
*.swp
*.swo
*~

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# 构建产物（如需要单独管理）
dist/
build/
public/

# 依赖
node_modules/
vendor/

# IDE
.idea/
.vscode/
*.sublime-*

# 测试覆盖率
coverage/
.nyc_output/
